<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Visión Naranja</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VisionNaranja.styles.css" asp-append-version="true" />
</head>
<body class="site-wrapper">

    <header class="custom-header">
        <nav class="navbar navbar-expand-sm navbar-dark container">
            <a class="navbar-brand brand-highlight" asp-area="" asp-controller="Home" asp-action="Index">
                Visión<span>Naranja</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse justify-content-end">
                <ul class="navbar-nav custom-nav-links">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Product" asp-action="Index">Mis Productos</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacidad</a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>

    <main role="main" class="main-content container my-4">
        @RenderBody()
    </main>

    <footer class="custom-footer">
        <div class="container footer-container">
            <div class="footer-logo-area">
                <img src="~/images/logo-footer.png" alt="Visión Naranja Logo" class="footer-logo" onerror="this.style.display='none'; textFallback.style.display='block';" />
                <span id="textFallback" style="display:none;" class="footer-brand-text">Visión Naranja</span>
            </div>
            <div class="footer-info-area">
                <p class="mb-0">&copy; 2026 - Visión Naranja. Todos los derechos reservados.</p>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="footer-link">Política de Privacidad</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>