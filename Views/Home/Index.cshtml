@using VisionNaranja.ViewModels.Home

@model HomeIndexViewModel;

@{
    ViewData["Title"] = "Catálogo";
}

<div class="catalog-wrapper">
    <div class="filter-section mb-5 p-4 rounded-4 shadow-sm">
        <h5 class="filter-title mb-3"><i class="fa-solid fa-sliders me-2"></i> Filtrar Catálogo</h5>
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label text-muted small fw-bold">Tipo de Producto</label>
                <select class="form-select custom-select">
                    <option value="">Todos los productos / servicios</option>
                    <option value="1">Artesanías</option>
                    <option value="2">Gastronomía</option>
                    <option value="3">Servicios Digitales</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label text-muted small fw-bold">Emprendedor</label>
                <select class="form-select custom-select">
                    <option value="">Todos los emprendedores</option>
                    <option value="1">María Carmen</option>
                    <option value="2">Carlos Espinoza</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label text-muted small fw-bold">Emprendimiento</label>
                <select class="form-select custom-select">
                    <option value="">Todos los negocios</option>
                    <option value="1">ArteSano Ec</option>
                    <option value="2">Café Don Naranja</option>
                </select>
            </div>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

        @foreach (var product in Model.Products)
        {
            <div class="col">
                <div class="product-card h-100">

                    <!-- CARRUSEL DE IMÁGENES -->
                    <div id="carouselProduct@(product.Id)" class="carousel slide product-carousel" data-bs-ride="carousel">

                        <div class="carousel-inner h-100">
                            @if (product.Media != null && product.Media.Any())
                            {
                                int index = 0;
                                // Ordenamos para que la imagen declarada como 'IsPrimary' sea la primera del carrusel
                                var orderedMedia = product.Media.OrderByDescending(m => m.IsPrimary);

                                foreach (var media in orderedMedia)
                                {
                                    <div class="carousel-item @(index == 0 ? "active" : "") h-100">
                                        <!-- Se asume que MediaPath ya trae la ruta web correcta -->
                                        <img src="/media/@media.MediaPath"
                                             class="d-block w-100 h-100 object-fit-cover"
                                             alt="@product.Name - Imagen @(index + 1)">
                                    </div>
                                    index++;
                                }
                            }
                            else
                            {
                                <!-- Imagen por defecto si el producto no tiene archivos multimedia -->
                                <div class="carousel-item active h-100">
                                    <img src="/images/no-product.png"
                                         class="d-block w-100 h-100 object-fit-cover"
                                         alt="Sin imagen disponible">
                                </div>
                            }
                        </div>

                        @if (product.Media != null && product.Media.Count() > 1)
                        {
                            <button class="carousel-control-prev"
                                    type="button"
                                    data-bs-target="#carouselProduct@(product.Id)"
                                    data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            </button>

                            <button class="carousel-control-next"
                                    type="button"
                                    data-bs-target="#carouselProduct@(product.Id)"
                                    data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            </button>
                        }
                    </div>

                    <!-- CUERPO DE LA TARJETA -->
                    <div class="product-card-body">

                        <!-- INFORMACIÓN DEL EMPRENDEDOR -->
                        <div class="branding-badge mb-3">
                            <img src="/media/@product.EntrepreneurProfilePhotoPath"
                                 class="entrepreneur-avatar"
                                 alt="Foto de @product.EntrepreneurName">

                            <div class="branding-text">
                                <a class="nav-link" 
                                    asp-controller="Home" 
                                    asp-route-id="@product.EntrepreneurId" 
                                    asp-action="Entrepreneur">

                                    <span class="entrepreneur-name">
                                        Por: @product.EntrepreneurName
                                    </span>
                                </a>

                                <a class="nav-link" 
                                    asp-controller="Home" 
                                    asp-route-id="@product.EntrepreneurshipId" 
                                    asp-action="Entrepreneurship">

                                    <span class="business-name">
                                        <i class="fa-solid fa-shop me-1"></i>
                                        @product.EntrepreneurshipName
                                    </span>
                                </a>
                            </div>

                            <img src="/media/@product.EntrepreneurshipLogoPath"
                                 class="business-logo"
                                 alt="Logo @product.EntrepreneurshipName">
                        </div>

                        <!-- DETALLES DEL PRODUCTO -->
                        <h5 class="product-title">
                            @product.Name
                        </h5>

                        <p class="product-description">
                            @product.Description
                        </p>

                        <!-- METADATOS Y ACCIONES -->
                        <div class="product-footer-meta mt-auto">
                            <div class="price-tag">
                                @if (product.Price.HasValue)
                                {
                                    @:$@product.Price.Value.ToString("N2")
                                }
                                else
                                {
                                    @:Gratis / Cotizar
                                }
                            </div>

                            <!-- Botón dinámico de WhatsApp con texto codificado para URL -->
                            @{
                                var whatsappText = Uri.EscapeDataString($"Hola {product.EntrepreneurName}, estoy interesado en tu producto: {product.Name} visto en Visión Naranja.");
                                var whatsappUrl = $"https://wa.me/{product.EntrepreneurCellPhoneNumber}?text={whatsappText}";
                            }
                            <a href="@whatsappUrl"
                               target="_blank"
                               class="btn btn-whatsapp">
                                <i class="fa-brands fa-whatsapp"></i>
                                Contactar
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>

</div>